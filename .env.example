# transfer.sh deployment configuration
# Copy to .env and adjust values. Do NOT commit the resulting .env.

# Container image (replace OWNER/REPO with your fork path, e.g. user/transfer.sh)
TRANSFERSH_IMAGE=ghcr.io/OWNER/REPO:latest

# Auto-purge: files are removed after PURGE_DAYS days; the cleanup loop runs
# every PURGE_INTERVAL hours.
PURGE_DAYS=360
PURGE_INTERVAL=24

# Upload limits
MAX_UPLOAD_SIZE=5242880   # in KB, default 5 GB
RATE_LIMIT=0              # requests per minute, 0 disables

# URL token length (longer = harder to guess)
RANDOM_TOKEN_LENGTH=10

# Run a ClamAV prescan before persisting the upload. Requires the clamav service.
PERFORM_CLAMAV_PRESCAN=true

# Comma-separated CIDRs that may upload without basic auth (optional).
HTTP_AUTH_IP_WHITELIST=

# Comma-separated CIDRs allowed / denied at the connection level (optional).
IP_WHITELIST=
IP_BLACKLIST=

# CORS: comma-separated list of allowed origins (optional).
CORS_DOMAINS=

# Set when running behind a reverse proxy on a non-standard path / port.
PROXY_PATH=
PROXY_PORT=

# Frontend "Contact us" mail link (optional).
EMAIL_CONTACT=

# Resource limits for the containers (Docker Compose deploy.resources).
TRANSFERSH_MEMORY_LIMIT=512M
CLAMAV_MEMORY_LIMIT=2G
